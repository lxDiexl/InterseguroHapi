{
  "name": "interseguro-matrix-api",
  "version": "1.0.0",
  "description": "API para análisis de matrices con arquitectura en capas y estándares Interseguro",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "keywords": ["interseguro", "matrix", "hapi", "typescript"],
  "author": "Interseguro",
  "license": "ISC",
  "dependencies": {
    "@hapi/hapi": "^21.3.2",
    "@hapi/boom": "^10.0.1",
    "@hapi/inert": "^7.1.0",
    "@hapi/vision": "^7.0.3",
    "joi": "^17.11.0",
    "dotenv": "^16.4.7",
    "winston": "^3.11.0",
    "uuid": "^9.0.1",
    "axios": "^1.6.5",
    "validator": "^13.11.0"
  },
  "devDependencies": {
    "@types/hapi__hapi": "^20.0.13",
    "@types/hapi__boom": "^10.0.0",
    "@types/hapi__inert": "^5.2.7",
    "@types/hapi__vision": "^5.5.5",
    "@types/node": "^20.11.1",
    "@types/jest": "^29.5.11",
    "@types/uuid": "^9.0.7",
    "@types/validator": "^13.11.8",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
